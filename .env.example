# Copie para .env e preencha os valores

# Banco de dados PostgreSQL (Railway fornece automaticamente via plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Ambiente NF-e: 1=Producao, 2=Homologacao
NFE_AMBIENTE=2

# Credenciais do painel administrativo
ADMIN_USER=admin
ADMIN_PASS=troqueaqui

# Chave secreta Flask (gere com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=troque-por-uma-chave-segura
